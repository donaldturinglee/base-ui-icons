  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/donaldturinglee/base-ui-icons/issues"
  },
  "homepage": "https://github.com/donaldturinglee/base-ui-icons#readme",
  "dependencies": {
    "@babel/generator": "^7.28.5",
    "@babel/types": "^7.28.5",
    "cheerio": "^1.1.2",
    "clsx": "^2.1.1",
    "fs-extra": "^11.3.2",
    "globby": "^15.0.0",
    "lodash.merge": "^4.6.2",
    "svgo": "^4.0.0",
    "svgson": "^5.3.1",
    "tailwind-merge": "^3.6.0",
    "trim-newlines": "^5.0.0",
    "yargs": "^18.0.0"
  }
